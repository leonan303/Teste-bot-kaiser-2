        await sock.sendMessage(from, {
          text: `🌐 *Tradução → ${idioma.toUpperCase()}:*\n\n📝 Original: ${txt}\n✅ Traduzido: ${d.responseData.translatedText}`
        })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) }) }
      break
    }

    // ── CÂMBIO ────────────────────────────────────────────────
    case 'moeda': case 'cambio': {
      const valor = parseFloat(args[1]) || 1
      const de    = (args[2] || 'USD').toUpperCase()
      const para  = (args[3] || 'BRL').toUpperCase()
      try {
        const r    = await fetch(`https://api.exchangerate-api.com/v4/latest/${de}`)
        const d    = await r.json()
        const taxa = d.rates[para]
        if (!taxa) throw new Error()
        await sock.sendMessage(from, {
          text: `💱 *Câmbio:*\n\n${valor} ${de} = *${(valor * taxa).toFixed(2)} ${para}*\n📊 1 ${de} = ${taxa.toFixed(4)} ${para}`
        })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_Moeda inválida?_' }) }
      break
