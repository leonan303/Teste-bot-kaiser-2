// ─── Conectar ────────────────────────────────────────────────
async function conectar() {
  const { state, saveCreds } = await useMultiFileAuthState('auth')

  const sock = makeWASocket({
    auth: state,
    logger: pino({ level: 'silent' }),
    browser: ['Kaiser Bot', 'Chrome', '1.0']
  })

  sock.ev.on('connection.update', async ({ connection, lastDisconnect, qr }) => {
    if (qr) {
      console.clear()
      console.log('╔══════════════════════════════════════╗')
      console.log('║  👑 KAISER BOT - Blue Lock Edition   ║')
      console.log('║     Michael Kaiser · Bastard München  ║')
      console.log('╚══════════════════════════════════════╝')
      qrcode.generate(qr, { small: true })
      console.log('📱 Escaneie o QR Code com seu WhatsApp!')
      console.log('   ⋮ > Dispositivos conectados > Conectar dispositivo')
    }
    if (connection === 'open') {
      console.log('✅ Kaiser entrou em campo!')
      setTimeout(() => definirPerfil(sock), 3000)
    }
    if (connection === 'close') {
      const reason = lastDisconnect?.error?.output?.statusCode
      if (reason !== DisconnectReason.loggedOut) {
        console.log('🔄 Kaiser está voltando...'); conectar()
      } else {
        console.log('🚪 Sessão encerrada. Delete a pasta "auth" e tente novamente.')
      }
    }
  })

  sock.ev.on('creds.update', saveCreds)

  sock.ev.on('messages.upsert', async ({ messages, type }) => {
    if (type !== 'notify') return
    for (const msg of messages) {
      try { await processarMensagem(sock, msg) }
      catch (e) { console.error('Erro:', e.message) }
    }
  })
}

// ─── Processador de mensagens ────────────────────────────────
async function processarMensagem(sock, msg) {
  if (!msg.message || msg.key.fromMe) return

  const from     = msg.key.remoteJid
  const isGroup  = from.endsWith('@g.us')
  const pushName = msg.pushName || 'Coadjuvante'

  const texto =
    msg.message?.conversation ||
    msg.message?.extendedTextMessage?.text ||
    msg.message?.imageMessage?.caption ||
    msg.message?.videoMessage?.caption || ''

  const args    = texto.trim().split(/\s+/)
  const cmd     = args[0]?.toLowerCase() || ''
  const resto   = args.slice(1).join(' ')

  if (!cmd.startsWith(PREFIX)) return
  const comando = cmd.slice(PREFIX.length)

  await sock.sendPresenceUpdate('composing', from)
  await delay(600)

  switch (comando) {

    // ── PING ──────────────────────────────────────────────────
    case 'ping':
      await sock.sendMessage(from, {
        text: `🏓 *Kaiser Impact* — resposta instantânea.\n_"Eu nunca perco tempo, nem em pings."_ 👑`
      })
      break

    // ── MENU ──────────────────────────────────────────────────
    case 'menu': case 'ajuda': case 'help':
      await sock.sendMessage(from, { text: gerarMenu() })
      break

    // ── OI ────────────────────────────────────────────────────
    case 'oi': case 'ola': case 'olá':
      await sock.sendMessage(from, { text: rand(KAISER_BOAS_VINDAS)(pushName) })
      break

    // ── FRASE DO KAISER ───────────────────────────────────────
    case 'kaiser': case 'frase': case 'quote':
      await sock.sendMessage(from, { text: `👑 *Michael Kaiser diz:*\n\n${rand(KAISER_FRASES)}` })
      break

    // ── INFO ──────────────────────────────────────────────────
    case 'info': case 'sobre':
      await sock.sendMessage(from, {
        text: `╔══════════════════════════════╗\n` +
              `║   👑 KAISER BOT - INFO        ║\n` +
              `╠══════════════════════════════╣\n` +
              `║ Personagem: Michael Kaiser   ║\n` +
              `║ Time: Bastard München        ║\n` +
              `║ Posição: Atacante            ║\n` +
              `║ Golpe: Kaiser Impact ⚡      ║\n` +
              `║ Versão: 2.0                  ║\n` +
              `║ Uptime: ${formatUptime().padEnd(20)}║\n` +
              `╚══════════════════════════════╝\n\n` +
              `_"Bem-vindo à minha dimensão."_ 🌹`
      })
      break

    // ── STATUS ────────────────────────────────────────────────
    case 'status': {
      const mem = process.memoryUsage()
      await sock.sendMessage(from, {
        text: `📊 *Status do Kaiser Bot:*\n\n` +
              `⏱️ Uptime: ${formatUptime()}\n` +
              `💾 RAM: ${(mem.heapUsed / 1024 / 1024).toFixed(2)} MB\n` +
              `📦 Node: ${process.version}\n\n` +
              `_"O Imperador nunca para."_ 👑`
      })
      break
    }

    // ── STICKER ───────────────────────────────────────────────
    case 'sticker': case 'fig': case 'figurinha': case 's': {
      const quoted   = msg.message?.extendedTextMessage?.contextInfo?.quotedMessage
      const mediaMsg = quoted || msg.message

      if (!mediaMsg?.imageMessage && !mediaMsg?.videoMessage) {
        await sock.sendMessage(from, {
          text: `🌹 *Kaiser explica:*\nEnvie uma *imagem* ou *vídeo* (até 10s) com *!sticker*\nOu responda uma mídia com o comando.\n_Simples. Até você consegue._`
        })
        break
      }

      const isVideo = !!mediaMsg.videoMessage
      const buffer  = await downloadMediaMessage(
        { message: mediaMsg, key: msg.key }, 'buffer', {},
        { logger: pino({ level: 'silent' }) }
      )
      const ext    = isVideo ? 'mp4' : 'jpg'
      const inFile = path.join(TMP, `stk_in.${ext}`)
      const outFile = path.join(TMP, 'stk_out.webp')
      fs.writeFileSync(inFile, buffer)

      await sock.sendMessage(from, { text: `⏳ _Kaiser convertendo figurinha..._` })

      if (isVideo) {
        await shell(`ffmpeg -y -i "${inFile}" -t 10 -vf "scale=512:512:force_original_aspect_ratio=decrease,fps=15,pad=512:512:(ow-iw)/2:(oh-ih)/2:color=white@0" -loop 0 -an -vsync 0 "${outFile}"`)
      } else {
        await shell(`ffmpeg -y -i "${inFile}" -vf "scale=512:512:force_original_aspect_ratio=decrease,pad=512:512:(ow-iw)/2:(oh-ih)/2:color=white@0" "${outFile}"`)
      }

      await sock.sendMessage(from, { sticker: fs.readFileSync(outFile) })
      try { fs.unlinkSync(inFile); fs.unlinkSync(outFile) } catch {}
      break
    }

    // ── STICKER COM TEXTO ─────────────────────────────────────
    case 'stext': case 'figtext': {
      if (!resto) {
        await sock.sendMessage(from, { text: `✏️ *Uso:* !stext <texto>\n_Ex: !stext Kaiser Impact_` })
        break
      }
      const imgF = path.join(TMP, 'stext.png')
      const outF = path.join(TMP, 'stext.webp')
      try {
        await sock.sendMessage(from, { text: `⏳ _Criando figurinha..._` })
        await shell(`ffmpeg -y -f lavfi -i "color=0x1a1a2e:size=512x512" -vf "drawtext=text='${resto.replace(/'/g, "\\'")}':fontcolor=white:fontsize=36:x=(w-text_w)/2:y=(h-text_h)/2" -frames:v 1 "${imgF}"`)
        await shell(`ffmpeg -y -i "${imgF}" "${outF}"`)
        await sock.sendMessage(from, { sticker: fs.readFileSync(outF) })
        try { fs.unlinkSync(imgF); fs.unlinkSync(outF) } catch {}
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) }) }
      break
    }

    // ── STICKER → IMAGEM ──────────────────────────────────────
    case 'toimg': case 'destig': {
      const quoted = msg.message?.extendedTextMessage?.contextInfo?.quotedMessage
      if (!quoted?.stickerMessage) {
        await sock.sendMessage(from, { text: `📌 Responda um *sticker* com *!toimg*\n_Isso é básico. Vamos lá._` })
        break
      }
      const buf  = await downloadMediaMessage({ message: quoted, key: msg.key }, 'buffer', {}, { logger: pino({ level: 'silent' }) })
      const inF  = path.join(TMP, 'stk2img.webp')
      const outF = path.join(TMP, 'stk2img.png')
      fs.writeFileSync(inF, buf)
      await shell(`ffmpeg -y -i "${inF}" "${outF}"`)
      await sock.sendMessage(from, { image: fs.readFileSync(outF), caption: `🖼️ _Kaiser converteu. De nada._` })
      try { fs.unlinkSync(inF); fs.unlinkSync(outF) } catch {}
      break
    }

    // ── YOUTUBE - VÍDEO ───────────────────────────────────────
    case 'yt': case 'ytv': case 'youtube': {
      if (!resto) { await sock.sendMessage(from, { text: `🎬 *Uso:* !yt <link ou nome do vídeo>` }); break }
      await sock.sendMessage(from, { text: `⏳ _Kaiser buscando seu vídeo..._\n🎬 *${resto}*` })
      try {
        const out = path.join(TMP, 'yt_video.mp4')
        if (fs.existsSync(out)) fs.unlinkSync(out)
        const q = resto.startsWith('http') ? `"${resto}"` : `"ytsearch1:${resto}"`
        await shell(`yt-dlp -f "best[ext=mp4][filesize<50M]/best[filesize<50M]" -o "${out}" ${q}`)
        await sock.sendMessage(from, {
          video: fs.readFileSync(out),
          caption: `🎬 _Entregue pelo Imperador. Você está em dívida._`
        })
        try { fs.unlinkSync(out) } catch {}
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_Verifique o link ou tente outro nome._' }) }
      break
    }

    // ── YOUTUBE - MP3 ─────────────────────────────────────────
    case 'mp3': case 'musica': case 'ytmp3': {
      if (!resto) { await sock.sendMessage(from, { text: `🎵 *Uso:* !mp3 <link ou nome>` }); break }
      await sock.sendMessage(from, { text: `⏳ _Baixando áudio..._\n🎵 *${resto}*` })
      try {
        const out = path.join(TMP, 'yt_audio.mp3')
        if (fs.existsSync(out)) fs.unlinkSync(out)
        const q = resto.startsWith('http') ? `"${resto}"` : `"ytsearch1:${resto}"`
        await shell(`yt-dlp -x --audio-format mp3 --audio-quality 0 -o "${out}" ${q}`)
        await sock.sendMessage(from, { audio: fs.readFileSync(out), mimetype: 'audio/mpeg', ptt: false })
        try { fs.unlinkSync(out) } catch {}
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) }) }
      break
    }

    // ── TIKTOK ────────────────────────────────────────────────
    case 'tiktok': case 'tk': {
      if (!resto?.startsWith('http')) { await sock.sendMessage(from, { text: `🎵 *Uso:* !tiktok <link>` }); break }
      await sock.sendMessage(from, { text: `⏳ _Baixando TikTok..._` })
      try {
        const out = path.join(TMP, 'tiktok.mp4')
        if (fs.existsSync(out)) fs.unlinkSync(out)
        await shell(`yt-dlp -o "${out}" "${resto}"`)
        await sock.sendMessage(from, { video: fs.readFileSync(out), caption: `🎵 _Kaiser Impact no TikTok._` })
        try { fs.unlinkSync(out) } catch {}
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_Link válido?_' }) }
      break
    }

    // ── INSTAGRAM ─────────────────────────────────────────────
    case 'insta': case 'ig': case 'instagram': {
      if (!resto?.startsWith('http')) { await sock.sendMessage(from, { text: `📸 *Uso:* !insta <link do post/reel>` }); break }
      await sock.sendMessage(from, { text: `⏳ _Baixando Instagram..._` })
      try {
        const base = path.join(TMP, 'insta_media')
        await shell(`yt-dlp -o "${base}.%(ext)s" "${resto}"`)
        const files = fs.readdirSync(TMP).filter(f => f.startsWith('insta_media.'))
        if (!files.length) throw new Error()
        const file = path.join(TMP, files[0])
        const isVid = ['mp4', 'mov', 'mkv'].includes(files[0].split('.').pop())
        if (isVid) {
          await sock.sendMessage(from, { video: fs.readFileSync(file), caption: `📸 _Entregue pelo Imperador._` })
        } else {
          await sock.sendMessage(from, { image: fs.readFileSync(file), caption: `📸 _Entregue pelo Imperador._` })
        }
        try { fs.unlinkSync(file) } catch {}
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_O link é público?_' }) }
      break
    }

    // ── TTS ───────────────────────────────────────────────────
    case 'tts': case 'falar': case 'audio': {
      if (!resto) { await sock.sendMessage(from, { text: `🔊 *Uso:* !tts <texto>\n_Ex: !tts Eu sou o Imperador_` }); break }
      await sock.sendMessage(from, { text: `🎙️ _Kaiser gravando áudio..._` })
      try {
        const out = path.join(TMP, 'tts.mp3')
        const tts = new gtts(resto, 'pt')
        await new Promise((res, rej) => tts.save(out, err => err ? rej(err) : res()))
        await sock.sendMessage(from, { audio: fs.readFileSync(out), mimetype: 'audio/mpeg', ptt: true })
        try { fs.unlinkSync(out) } catch {}
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) }) }
      break
    }

    // ── PIADA ─────────────────────────────────────────────────
    case 'piada': case 'joke':
      await sock.sendMessage(from, { text: `😏 *Kaiser conta uma piada:*\n\n${rand(KAISER_PIADAS)}` })
      break

    // ── CEP ───────────────────────────────────────────────────
    case 'cep': {
      if (!resto) { await sock.sendMessage(from, { text: `📮 *Uso:* !cep <número>\n_Ex: !cep 01001000_` }); break }
      const cepNum = resto.replace(/\D/g, '')
      try {
        const r = await fetch(`https://viacep.com.br/ws/${cepNum}/json/`)
        const d = await r.json()
        if (d.erro) throw new Error()
        await sock.sendMessage(from, {
          text: `📮 *CEP ${cepNum}:*\n\n🏠 ${d.logradouro || '-'}\n🏘️ ${d.bairro || '-'}\n🏙️ ${d.localidade} - ${d.uf}`
        })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_CEP inválido._' }) }
      break
    }

    // ── CLIMA ─────────────────────────────────────────────────
    case 'clima': case 'tempo': {
      if (!resto) { await sock.sendMessage(from, { text: `🌤️ *Uso:* !clima <cidade>` }); break }
      try {
        const r   = await fetch(`https://wttr.in/${encodeURIComponent(resto)}?format=j1`)
        const d   = await r.json()
        const cur = d.current_condition[0]
        await sock.sendMessage(from, {
          text: `🌤️ *Clima em ${resto}:*\n\n🌡️ Temp: *${cur.temp_C}°C* (sensação ${cur.FeelsLikeC}°C)\n☁️ ${cur.weatherDesc[0].value}\n💧 Umidade: ${cur.humidity}%\n💨 Vento: ${cur.windspeedKmph} km/h\n\n_"Até o tempo respeita o Imperador."_ 👑`
        })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) }) }
      break
    }

    // ── TRADUÇÃO ──────────────────────────────────────────────
    case 'tr': case 'traduzir': {
      const idioma = args[1] || 'en'
      const txt    = args.slice(2).join(' ')
      if (!txt) { await sock.sendMessage(from, { text: `🌐 *Uso:* !tr <idioma> <texto>\n_Ex: !tr en Eu sou o Imperador_` }); break }
      try {
        const r = await fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(txt)}&langpair=pt|${idioma}`)
