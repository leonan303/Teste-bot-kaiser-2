    // ── WIKIPEDIA ─────────────────────────────────────────────
    case 'wiki': case 'wikipedia': {
      if (!resto) { await sock.sendMessage(from, { text: `📚 *Uso:* !wiki <tema>` }); break }
      try {
        const r = await fetch(`https://pt.wikipedia.org/api/rest_v1/page/summary/${encodeURIComponent(resto)}`)
        const d = await r.json()
        if (!d.extract) throw new Error()
        const txt = d.extract.length > 700 ? d.extract.substring(0, 700) + '...' : d.extract
        await sock.sendMessage(from, {
          text: `📚 *Wikipedia: ${d.title}*\n\n${txt}\n\n🔗 ${d.content_urls?.desktop?.page || ''}`
        })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_Tema não encontrado._' }) }
      break
    }

    // ── LETRA DE MÚSICA ───────────────────────────────────────
    case 'letra': case 'lyrics': {
      const partes  = resto.split('-')
      const artista = partes[0]?.trim()
      const musica  = partes[1]?.trim()
      if (!artista || !musica) {
        await sock.sendMessage(from, { text: `🎵 *Uso:* !letra Artista - Música` })
        break
      }
      try {
        const r = await fetch(`https://api.lyrics.ovh/v1/${encodeURIComponent(artista)}/${encodeURIComponent(musica)}`)
        const d = await r.json()
        if (!d.lyrics) throw new Error()
        const letra = d.lyrics.length > 1500 ? d.lyrics.substring(0, 1500) + '\n...' : d.lyrics
        await sock.sendMessage(from, { text: `🎵 *${musica} - ${artista}:*\n\n${letra}` })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_Letra não encontrada._' }) }
      break
    }

    // ── CALCULADORA ───────────────────────────────────────────
    case 'calc': case 'calcular': {
      if (!resto) { await sock.sendMessage(from, { text: `🧮 *Uso:* !calc <expressão>\n_Ex: !calc 2+2*10_` }); break }
      try {
        const expr = resto.replace(/[^0-9+\-*/.() ]/g, '')
        // eslint-disable-next-line no-new-func
        const res  = new Function(`return ${expr}`)()
        await sock.sendMessage(from, { text: `🧮 *${resto} = ${res}*\n_"Calculei na velocidade do Kaiser Impact."_ ⚡` })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) + '\n_Expressão inválida._' }) }
      break
    }

    // ── IMC ───────────────────────────────────────────────────
    case 'imc': {
      const peso = parseFloat(args[1])
      const alt  = parseFloat(args[2])
      if (!peso || !alt) { await sock.sendMessage(from, { text: `⚖️ *Uso:* !imc <peso_kg> <altura_m>` }); break }
      const imc = (peso / (alt * alt)).toFixed(2)
      const cl  = imc < 18.5 ? '🔵 Abaixo do peso' : imc < 25 ? '🟢 Normal' : imc < 30 ? '🟡 Sobrepeso' : imc < 35 ? '🟠 Obesidade I' : '🔴 Obesidade II+'
      await sock.sendMessage(from, {
        text: `⚖️ *IMC:*\n\nPeso: ${peso}kg | Altura: ${alt}m\nIMC: *${imc}* — ${cl}\n\n_"Kaiser Impact tem 0% de gordura."_ 😏`
      })
      break
    }

    // ── ENCURTAR LINK ─────────────────────────────────────────
    case 'encurtar': case 'link': {
      if (!resto?.startsWith('http')) { await sock.sendMessage(from, { text: `🔗 *Uso:* !encurtar <url>` }); break }
      try {
        const r    = await fetch(`https://tinyurl.com/api-create.php?url=${encodeURIComponent(resto)}`)
        const link = await r.text()
        await sock.sendMessage(from, { text: `🔗 *Link encurtado:*\n${link}` })
      } catch { await sock.sendMessage(from, { text: rand(KAISER_ERROS) }) }
      break
    }

    // ── DADO ──────────────────────────────────────────────────
    case 'dado': case 'dice': {
      const lados = parseInt(args[1]) || 6
      const res   = Math.floor(Math.random() * lados) + 1
      await sock.sendMessage(from, {
        text: `🎲 *Dado de ${lados} lados:* ${res}\n_"Não preciso de dado. Eu já sei o futuro."_ 👑`
      })
      break
    }

    // ── CARA OU COROA ─────────────────────────────────────────
    case 'cara': case 'coin':
      await sock.sendMessage(from, {
        text: Math.random() < 0.5
          ? `👑 *Coroa!* — O Imperador sempre cai de pé.`
          : `🪙 *Cara!* — Até na moeda, minha cara aparece.`
      })
      break

    // ── ALEATÓRIO ─────────────────────────────────────────────
    case 'random': case 'numero': {
      const min = parseInt(args[1]) || 1
      const max = parseInt(args[2]) || 100
      const n   = Math.floor(Math.random() * (max - min + 1)) + min
      await sock.sendMessage(from, {
        text: `🔢 Entre ${min} e ${max}: *${n}*\n_"Calculei antes de você perguntar."_ 👑`
      })
      break
    }

    // ── ARTE ──────────────────────────────────────────────────
    case 'arte': {
      const artes = [
        `👑 ᕦ(ò_óˇ)ᕤ 🌹`,
        `(ノ°▽°)ノ⌒✿`,
        `¯\\_(ツ)_/¯`,
        `(づ｡◕‿‿◕｡)づ`,
        `⚡ ᕙ(⇀‸↼‶)ᕗ ⚡`,
        `(ˆ▿ˆ) 👑`,
        `🌹 (っ◔◡◔)っ ♥ 🌹`,
      ]
      await sock.sendMessage(from, { text: rand(artes) })
      break
    }

    // ── HORA ──────────────────────────────────────────────────
    case 'hora': case 'data':
      await sock.sendMessage(from, {
        text: `🕐 *Data e Hora (Brasília):*\n${new Date().toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' })}\n\n_"Cada segundo é meu."_ 👑`
      })
      break

    // ── MARCAR TODOS ──────────────────────────────────────────
    case 'todos': case 'all': {
      if (!isGroup) { await sock.sendMessage(from, { text: `❌ _Só funciona em grupos, maldito._` }); break }
      const meta    = await sock.groupMetadata(from)
      const members = meta.participants.map(p => p.id)
      let txt = `👑 *${pushName} convoca todos por ordem do Imperador!*\n\n`
      members.forEach(m => { txt += `@${m.split('@')[0]} ` })
      await sock.sendMessage(from, { text: txt, mentions: members })
      break
    }

    // ── GRUPO INFO ────────────────────────────────────────────
    case 'grupo': case 'grupoinfo': {
      if (!isGroup) { await sock.sendMessage(from, { text: `❌ _Grupos apenas, coadjuvante._` }); break }
      const meta = await sock.groupMetadata(from)
      await sock.sendMessage(from, {
        text: `👥 *Info do Grupo:*\n\n📛 ${meta.subject}\n👤 Membros: ${meta.participants.length}\n📅 Criado: ${new Date(meta.creation * 1000).toLocaleDateString('pt-BR')}\n📝 ${meta.desc || 'Sem descrição'}`
      })
      break
    }

    // ── SORTEIO ───────────────────────────────────────────────
    case 'sorteio': case 'sortear': {
      if (!isGroup) { await sock.sendMessage(from, { text: `❌ _Só em grupos._` }); break }
      const meta     = await sock.groupMetadata(from)
      const sorteado = rand(meta.participants)
      await sock.sendMessage(from, {
        text: `🎉 *Sorteio do Kaiser:*\n\nO escolhido foi @${sorteado.id.split('@')[0]} 🏆\n_"O Imperador decidiu. Sem questionamentos."_`,
        mentions: [sorteado.id]
      })
      break
    }

    // ── ENQUETE ───────────────────────────────────────────────
    case 'enquete': {
      const partes = resto.split('|').map(s => s.trim())
      if (partes.length < 3) {
        await sock.sendMessage(from, { text: `📊 *Uso:* !enquete Pergunta? | Opção 1 | Opção 2\n_Máximo 4 opções._` })
        break
      }
      await sock.sendMessage(from, {
        poll: { name: partes[0], values: partes.slice(1, 5), selectableCount: 1 }
      })
      break
    }

    // ── CHECAR FAKE NEWS ──────────────────────────────────────
    case 'checar': case 'fake':
      await sock.sendMessage(from, {
        text: `🔍 *Kaiser verifica:*\n_"${resto || 'isso'}"_\n\n⚠️ Confirme em fontes sérias:\n• lupa.news\n• aosfatos.org\n• boatos.org\n• g1.globo.com/fato-ou-fake\n\n_"Mentira não dura. O Kaiser dura."_ 👑`
      })
      break

    // ── INFO MÍDIA ────────────────────────────────────────────
    case 'info_midia': {
      const quoted = msg.message?.extendedTextMessage?.contextInfo?.quotedMessage
      if (!quoted) { await sock.sendMessage(from, { text: `📌 Responda uma mídia com *!info_midia*` }); break }
      await sock.sendMessage(from, { text: `ℹ️ *Tipo:* ${getContentType(quoted) || 'Desconhecido'}` })
      break
    }

    default:
      break
  }

  await sock.sendPresenceUpdate('paused', from)
}

